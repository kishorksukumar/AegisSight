# ── AegisSight v0.2 Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values before running ./install.sh

# ── Initial Admin Credentials (set on first boot only) ───────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe!

# ── Domain & TLS ─────────────────────────────────────────────────────────────
# The public domain you want AegisSight accessible at
DOMAIN=your-domain.com

# Email address used for Let's Encrypt registration and expiry notices
LETSENCRYPT_EMAIL=admin@your-domain.com

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=4000

# Encryption key for AES-256 credential storage (auto-generated if blank)
ENCRYPTION_KEY=
